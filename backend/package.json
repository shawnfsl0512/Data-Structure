{
  "name": "backend",
  "version": "1.0.0",
  "description": "后端服务",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "npm run build && node dist/app.js",
    "start": "npm run build && node dist/app.js",
    "test": "jest",
    "check-data": "ts-node src/scripts/checkDataReady.ts",
    "check:coordinates": "ts-node src/scripts/checkCoordinateOverlaps.ts",
    "refresh:scenic-tags": "set DB_LOGGING=false&& ts-node src/scripts/refreshScenicTags.ts",
    "apply-campus-template:hzau": "set DB_LOGGING=false&& ts-node src/scripts/applyHzauTemplateToCampuses.ts",
    "apply-scenic-template:hzau": "set DB_LOGGING=false&& ts-node src/scripts/applyHzauTemplateToScenicAreas.ts",
    "clear-campus-internal-data": "set DB_LOGGING=false&& ts-node src/scripts/clearCampusInternalData.ts",
    "migrate:runtime-templates": "set DB_LOGGING=false&& ts-node src/scripts/migrateInternalMapsToRuntimeTemplates.ts",
    "repair-data:arrays": "set DB_LOGGING=false&& ts-node src/scripts/repairSerializedArrays.ts",
    "setup:data": "npm run import-data:real-template",
    "setup:data:with-covers": "npm run import-data:real-template && npm run import-covers:v2",
    "import-data": "set DB_LOGGING=false&& ts-node src/scripts/dataImport.ts",
    "import-data:grid": "set DB_LOGGING=false&& set DATA_IMPORT_MAP_MODE=grid&& ts-node src/scripts/dataImport.ts",
    "import-data:real-template": "set DB_LOGGING=false&& set DATA_IMPORT_MAP_MODE=shared_real_template&& ts-node src/scripts/dataImport.ts",
    "process-map:hzau": "set DB_LOGGING=false&& ts-node src/scripts/processHzauCampusMap.ts",
    "import-covers": "ts-node src/scripts/importWikimediaCovers.ts",
    "import-covers:v2": "ts-node src/scripts/importWikimediaCoversV2.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.4",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "redis": "^4.6.8",
    "socket.io": "^4.7.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.17",
    "uuid": "^11.1.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.4",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.5.0",
    "@types/pg": "^8.10.2",
    "jest": "^29.6.4",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
